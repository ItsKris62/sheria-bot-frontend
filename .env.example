# SheriaBot Frontend Environment Variables
# For local dev: copy to .env.local and set your values
# For Vercel: set these in the Vercel dashboard → Settings → Environment Variables

# Backend API URL (tRPC endpoint)
# Local dev:  http://localhost:4000/trpc
# Production: https://<your-render-service>.onrender.com/trpc
NEXT_PUBLIC_API_URL=http://localhost:4000/trpc

# Frontend app URL (this app)
# Local dev:  http://localhost:3000
# Production: https://<your-vercel-app>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (browser/server/edge error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/0000000
# Required by `withSentryConfig` when uploading source maps in CI/deploy builds.
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Cloudflare R2 public bucket base URL (no trailing slash)
# Production: https://pub-<id>.r2.dev
NEXT_PUBLIC_R2_ASSETS_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
