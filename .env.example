# SheriaBot Frontend Environment Variables
# For local dev: copy to .env.local and set your values
# For Vercel: set these in the Vercel dashboard → Settings → Environment Variables

# Backend API URL (tRPC endpoint)
# Local dev:  http://localhost:4000/trpc
# Production: https://<your-render-service>.onrender.com/trpc
NEXT_PUBLIC_API_URL=http://localhost:4000/trpc

# Frontend app URL (this app)
# Local dev:  http://localhost:3000
# Production: https://<your-vercel-app>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
